NODE_ENV=production
PORT=8787
APP_BASE_URL=https://onlywrite.example.com
DATABASE_URL=/data/onlywrite.sqlite
WEBSITE_DIST=/app/apps/website/dist
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_SESSION_MAX_AGE_SECONDS=2592000

LOGTO_ISSUER=https://auth.example.com/oidc
LOGTO_JWKS_URI=https://auth.example.com/oidc/jwks
LOGTO_APP_ID=replace-with-logto-app-id
LOGTO_APP_SECRET=replace-with-logto-app-secret
LOGTO_SCOPES=openid profile email

LOGTO_MANAGEMENT_APP_ID=replace-with-logto-management-app-id
LOGTO_MANAGEMENT_APP_SECRET=replace-with-logto-management-app-secret
LOGTO_MANAGEMENT_API_URL=https://auth.example.com/api
LOGTO_MANAGEMENT_RESOURCE=https://default.logto.app/api

LLM_API_KEY=replace-with-llm-api-key
LLM_MODEL=gpt-4.1-mini
LLM_BASE_URL=https://api.openai.com/v1
LLM_STREAM_API=responses
LLM_TIMEOUT_MS=120000
SOURCE_FETCH_TIMEOUT_MS=15000
